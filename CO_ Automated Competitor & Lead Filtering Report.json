    {
      "parameters": {
        "jsCode": "// Get the aggregated array of jobs\n// Make sure \"job_list\" matches the \"Destination Field Name\" in your Aggregate node\nconst jobs = $input.item.json.job_list || [];\n\n// Prepare the HTML structure for the email header\nlet email_html = `\n  <div style=\"font-family: Arial, sans-serif; line-height: 1.6; color: #333;\">\n    <h2 style=\"color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 8px;\">\n      🏥 Daily Healthcare Leads Report\n    </h2>\n    <p>\n      Good morning! The system has found <b>${jobs.length}</b> new potential leads in the last 24 hours.\n      Competitors and Medical Doctors have been automatically filtered out.\n    </p>\n    <hr style=\"border: 0; border-top: 1px solid #eee; margin: 20px 0;\">\n`;\n\n// Loop through each job and format it as an individual block\nfor (let i = 0; i < jobs.length; i++) {\n    const job = jobs[i];\n\n    // Create a clickable link if the URL exists\n    const job_link = job.url\n        ? `<a href=\"${job.url}\" target=\"_blank\" style=\"color: #3498db; text-decoration: none;\">Click here to view job posting</a>`\n        : 'Link not provided';\n\n    email_html += `\n    <div style=\"margin-bottom: 25px; padding: 15px; background-color: #f9f9f9; border-radius: 8px; border-left: 4px solid #3498db;\">\n        <h3 style=\"margin-top: 0; color: #2980b9;\">${i + 1}. ${job.title || 'Untitled Job'}</h3>\n        <ul style=\"list-style-type: none; padding-left: 0; margin-bottom: 0;\">\n            <li style=\"margin-bottom: 8px;\">🏢 <b>Hiring Company:</b> ${job.company_name || 'Not provided'}</li>\n            <li style=\"margin-bottom: 8px;\">🤖 <b>AI Reasoning:</b> ${job.reason || 'No reasoning provided'}</li>\n            <li style=\"margin-bottom: 0;\">🔗 <b>Job Link:</b> ${job_link}</li>\n        </ul>\n    </div>\n    `;\n}\n\n// Add the email footer\nemail_html += `\n    <hr style=\"border: 0; border-top: 1px solid #eee; margin: 20px 0;\">\n    <p style=\"font-size: 13px; color: #7f8c8d;\">\n      This report was automatically generated by n8n and AI.<br>\n      Please review the leads above and contact the suitable organizations via your Gmail Drafts or the provided links.\n    </p>\n  </div>\n`;\n\n// Output the final HTML string to the next node (Gmail)\nreturn {\n  json: {\n    email_html: email_html\n  }\n};"
      },
