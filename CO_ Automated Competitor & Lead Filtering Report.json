        "jsCode": "const queries = [\n  '(\"Nurse\" OR \"RN\" OR \"EN\" OR \"Health Caregiver\")',\n  '(\"PCW\" OR \"Physical Therapist\" OR \"PT\" OR \"OT\")',\n  '(\"Speech Therapist\" OR \"Nutritionist\" OR \"Social Worker\" OR \"RSW\")'\n];\n\nconst allRequests = [];\n\nfor (const query of queries) {\n  for (const start of [0, 10]) {\n    allRequests.push({\n      json: {\n        query,\n        location: 'Hong Kong',\n        start,\n      },\n    });\n  }\n}\n\nreturn allRequests;"
